# Wajah AI — First Try

# 1. Buat virtual environment
python3 -m venv venv
source venv/bin/activate

# 2. Install dependencies
pip install -r requirements.txt

# 3. Jalankan dashboard
python dashboard.py

# 4. Buka browser
# http://127.0.0.1:8000

# 5. Masukkan keyword pencarian (harus ada kata pria atau wanita)
# Contoh: pria face natural headshot close up plain background age 30 raw portrait
# Contoh: wanita face front view close up natural skin no makeup age 25

# 6. Masukkan jumlah gambar yang diminta lalu klik Start

# 7. Review hasil di 3 tab: Approved / Rejected / Review
#    - Koreksi jika ada yang salah

# 8. Klik Finish setelah selesai review
